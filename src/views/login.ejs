<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Salud - Iniciar Sesión</title>
    <link rel="stylesheet" href="/css/styles_login.css">
</head>

<body>
    <main class="container">
        <div class="form-container">
            <center><p class="logo-text">Bienvenido a Nova Salud</p></center>
            <center><h3>Iniciar Sesión</h3></center>
            <% if (error) { %>
                <div class="error-message">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/login" method="POST">
                        <input type="email" name="email" placeholder="Correo Electrónico" required>
                        <input type="password" name="password" placeholder="Contraseña" required>
                        <button type="submit">Ingresar al Sistema</button>
                    </form>
        </div>
        <div class="character-panel">
            <img src="https://png.pngtree.com/png-clipart/20250430/original/pngtree-colorful-cartoon-pharmacy-design-png-image_20897310.png"
                alt="Farmacia 3D Nova Salud">
        </div>
    </main>
</body>

</html>