<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Ventas - Nova Salud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_ventas.css">
</head>
<body>
    <main class="container ventas-container">
        <div class="header-top">
            <a href="/" class="btn-volver"><i class="fa-solid fa-arrow-left"></i> Volver al Inventario</a>
            <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</a>
        </div>
        <div class="titulos">
            <h1><i class="fa-solid fa-chart-line"></i> Historial de Ventas</h1>
            <p class="subtitle">Reporte general de ingresos y atenciones a pacientes</p>
        </div>
        <div class="table-wrapper">
            <div class="scroll-area">
                <table width="100%">
                    <thead>
                        <tr>
                            <th><i class="fa-regular fa-calendar-days"></i> Fecha y Hora</th>
                            <th><i class="fa-solid fa-user-injured"></i> Paciente</th>
                            <th><i class="fa-solid fa-pills"></i> Medicamento</th>
                            <th style="text-align: center;">Cant.</th>
                            <th style="text-align: right;"><i class="fa-solid fa-sack-dollar"></i> Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let totalIngresos = 0; %>
                        <% for(let i = 0; i < ventas.length; i++) { %>
                            <% totalIngresos += ventas[i].precioVenta; %>
                            <tr>
                                <td class="fecha-venta"><%= ventas[i].fecha %></td>
                                <td>
                                    <strong><%= ventas[i].clienteNombre || 'Público General' %></strong><br>
                                    <span style="font-size: 0.8em; color: #64748b;">DNI: <%= ventas[i].clienteDni || 'S/N' %></span>
                                </td>
                                <td class="venta-nombre"><%= ventas[i].nombreProducto %></td>
                                <td style="text-align: center; font-weight: bold;"><%= ventas[i].cantidad || 1 %></td>
                                <td class="venta-precio" style="text-align: right;">S/ <%= ventas[i].precioVenta.toFixed(2) %></td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            <table width="100%">
                <tfoot>
                    <tr class="tabla-footer">
                        <td class="footer-texto" style="text-align: right; padding-right: 20px; width: 80%;">TOTAL INGRESOS:</td>
                        <td class="footer-total" style="text-align: right;">S/ <%= totalIngresos.toFixed(2) %></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        document.querySelectorAll('.fecha-venta').forEach(celda => {
            const fechaCruda = new Date(celda.innerText);
            celda.innerText = fechaCruda.toLocaleString('es-PE', { 
                dateStyle: 'short', 
                timeStyle: 'short' 
            });
        });

        socket.on('catalogo-actualizado', () => {
            window.location.reload();
        });
    </script>
</body>
</html>