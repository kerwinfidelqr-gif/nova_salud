<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Usuarios - Nova Salud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_users.css">
</head>

<body>
    <main class="container">
        <div class="header-top">
            <div class="titulos">
                <h1>Gestión de Usuarios</h1>
                <p class="subtitle">Administra las cuentas del personal</p>
            </div>
            <div class="botones-top">
                <a href="/" class="btn-volver-inv"><i class="fa-solid fa-arrow-left"></i> Volver al Inventario</a>
                <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</a>
            </div>
        </div>
        
        <hr class="divider">

        <div class="form-container">
            <h3><i class="fa-solid fa-user-plus"></i> Registrar Nuevo Usuario</h3>
            <form action="/users/crear" method="POST" class="form-usuario">
                <input type="text" name="name" placeholder="Nombre" required>
                <input type="text" name="lastname" placeholder="Apellido" required>
                <input type="email" name="email" placeholder="Correo Electrónico" required>
                <input type="password" name="password" placeholder="Contraseña" required>
                <select name="role" required>
                    <option value="" disabled selected>Seleccionar rol</option>
                    <option value="admin">Admin</option>
                    <option value="almacen">Almacén</option>
                    <option value="ventas">Ventas</option>
                </select>
                <button type="submit" class="btn-guardar">
                    <i class="fa-solid fa-save"></i> Guardar
                </button>
            </form>
        </div>

        <div class="table-wrapper table-espaciada">
            <h3 class="table-title"><i class="fa-solid fa-users"></i> Usuarios Registrados</h3>
            
            <div class="scroll-area">
                <table width="100%">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (usuarios && usuarios.length > 0) { %>
                            <% for(let user of usuarios) { %>
                            <tr>
                                <td><strong><%= user.name %></strong></td>
                                <td><%= user.lastname %></td>
                                <td><%= user.email %></td>
                                <td><span class="role-badge"><%= user.role %></span></td>
                                <td class="text-center">
                                    <form action="/users/eliminar/<%= user._id %>" method="POST" class="form-inline" onsubmit="return confirm('¿Estás seguro de eliminar a <%= user.email %>?');">
                                        <button type="submit" class="btn-eliminar-usuario" title="Eliminar Usuario">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="empty-state-row">No hay usuarios registrados en el sistema.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>

</html>