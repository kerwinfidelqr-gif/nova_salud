<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Usuarios - Nova Salud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_index.css">
    <style>
        .container { max-width: 1100px; }
        .form-usuario {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr auto;
            gap: 10px;
            align-items: center;
        }
        .form-usuario input, .form-usuario select {
            height: 40px;
            padding: 0 10px;
            border: 1px solid rgba(100, 181, 246, 0.4);
            border-radius: 8px;
            font-size: 0.9rem;
        }
        .form-usuario select {
            background: white;
        }
        .btn-guardar {
            height: 40px;
            padding: 0 20px;
            background: linear-gradient(135deg, #42A5F5, #1565C0);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-eliminar-usuario {
            background: #EF5350;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <main class="container">
        <div class="header-top">
            <div class="titulos">
                <h1>Gestión de Usuarios</h1>
                <p class="subtitle">Administra las cuentas del personal</p>
            </div>
            <div class="botones-top">
                <a href="/" class="btn-logout" style="background: #1565C0; margin-right: 10px;">Volver al Inventario</a>
                <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</a>
            </div>
        </div>
        <hr class="divider">

        <!-- Formulario para crear usuario -->
        <div class="form-container">
            <h3><i class="fa-solid fa-user-plus"></i> Registrar Nuevo Usuario</h3>
            <form action="/users/crear" method="POST" class="form-usuario">
                <input type="text" name="name" placeholder="Nombre" required>
                <input type="text" name="lastname" placeholder="Apellido" required>
                <input type="email" name="email" placeholder="Correo Electrónico" required>
                <input type="password" name="password" placeholder="Contraseña" required>
                <select name="role" required>
                    <option value="">Seleccionar rol</option>
                    <option value="admin">Admin</option>
                    <option value="almacen">Almacén</option>
                    <option value="ventas">Ventas</option>
                </select>
                <button type="submit" class="btn-guardar"><i class="fa-solid fa-save"></i> Guardar</button>
            </form>
        </div>

        <!-- Tabla de usuarios -->
        <div class="table-wrapper" style="margin-top: 25px;">
            <h3 style="padding: 10px 20px; color: #1565C0;"><i class="fa-solid fa-list"></i> Usuarios Registrados</h3>
            <div class="scroll-area">
                <table width="100%">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th style="text-align: center;">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (usuarios && usuarios.length > 0) { %>
                            <% for(let user of usuarios) { %>
                            <tr>
                                <td><%= user.name %></td>
                                <td><%= user.lastname %></td>
                                <td><%= user.email %></td>
                                <td><span style="background: #E3F2FD; color: #1565C0; padding: 2px 10px; border-radius: 4px;"><%= user.role %></span></td>
                                <td style="text-align: center;">
                                    <form action="/users/eliminar/<%= user._id %>" method="POST" style="display: inline;" onsubmit="return confirm('¿Eliminar a <%= user.email %>?');">
                                        <button type="submit" class="btn-eliminar-usuario"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                            <% } %>
                        <% } else { %>
                            <tr><td colspan="5" style="text-align: center; padding: 50px; color: #64748B;">No hay usuarios registrados.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>