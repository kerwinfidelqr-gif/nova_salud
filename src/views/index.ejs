<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Salud - Inventario</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_index.css">
</head>
<body>
    <main class="container">
        <div class="header-top">
            <div class="titulos">
                <h1>Sistema de Gestión - Nova Salud</h1>
                <p class="subtitle">Gestión y control de inventario de medicamentos</p>
            </div>
            <div class="botones-top">
                <% if (role==='admin' ) { %>
                    <a href="/users" class="btn-reporte" style="background: #FFA726; margin-right: 10px;">Gestionar Usuarios</a>
                    <a href="/ventas" class="btn-reporte">Ver Historial</a>
                <% } %>
                        <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar
                            Sesión</a>
            </div>
        </div>
        <div id="alertas-sistema"></div>
        <hr class="divider">
        <% if (role==='admin' ) { %>
            <div class="form-container">
                <h3>Registrar Nuevo Medicamento</h3>
                <form action="/productos" method="POST" class="form-registro">
                    <input type="text" name="nombre" placeholder="Nombre (Ej: Paracetamol)" required>
                    <input type="number" name="precio" placeholder="Precio" step="0.10" required>
                    <input type="number" name="stock" placeholder="Stock Actual" required>
                    <input type="number" name="minimoStock" placeholder="Stock Mínimo" required>
                    <button type="submit" class="btn-guardar">Guardar</button>
                </form>
            </div>
            <% } %>
                <div class="table-header-title" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h3 style="margin-bottom: 0;">Inventario Actual</h3>
                    <input type="text" id="buscador-medicamentos" placeholder="Buscar medicamento..." 
                        style="width: 300px; height: 38px; padding: 0 15px; border: 1px solid rgba(100, 181, 246, 0.4); border-radius: 10px; font-size: 0.9rem; outline: none; background-color: rgba(255, 255, 255, 0.95);">
                </div>
                <div class="table-wrapper">
                    <% if (productos && productos.length> 0) { %>
                        <div class="scroll-area">
                            <table width="100%">
                                <thead>
                                    <tr>
                                        <th>Medicamento</th>
                                        <th>Precio</th>
                                        <th>Stock Actual</th>
                                        <th>Stock Mínimo</th>
                                        <th style="text-align: center;">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for(let i=0; i < productos.length; i++) { %>
                                        <tr>
                                            <td class="med-name">
                                                <%= productos[i].nombre %>
                                            </td>
                                            <td>S/ <%= productos[i].precio %>
                                            </td>
                                            <td id="stock-<%= productos[i]._id %>">
                                                <span
                                                    class="<%= productos[i].stock <= productos[i].minimoStock ? 'alerta-stock-texto' : 'stock-normal' %>">
                                                    <%= productos[i].stock %>
                                                </span>
                                            </td>
                                            <td>
                                                <%= productos[i].minimoStock %>
                                            </td>
                                            <td class="acciones-td">
                                                <a href="/editar/<%= productos[i]._id %>" class="btn-editar">Editar</a>
                                                <form action="/eliminar/<%= productos[i]._id %>" method="POST"
                                                    class="form-eliminar"
                                                    onsubmit="return confirm('¿Eliminar <%= productos[i].nombre %>?');">
                                                    <button type="submit" class="btn-eliminar">Eliminar</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fa-solid fa-box-open"></i>
                                <p>No hay medicamentos registrados en el inventario actual.</p>
                            </div>
                            <% } %>
                </div>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        socket.emit('identificar-rol', '<%= role %>');
        const alertasDiv = document.getElementById('alertas-sistema');

        socket.on('alerta-stock', (data) => {
            const alerta = document.createElement('div');
            alerta.className = 'alerta-caja';
            alerta.innerHTML = `<strong>Aviso:</strong> ${data.mensaje}`;
            alertasDiv.appendChild(alerta);
            setTimeout(() => { alerta.remove(); }, 4000);
        });
        socket.on('sincronizar-stock', (data) => {
            const celdaStock = document.getElementById('stock-' + data.idProducto);
            if (celdaStock) {
                const span = celdaStock.querySelector('span');
                if (span) span.innerText = data.nuevoStock;
            }
        });

        // Agrega esto justo debajo de tus otros socket.on(...)
        socket.on('catalogo-actualizado', () => {
            // Cuando el servidor grite que el catálogo cambió, recargamos la página suavemente
            window.location.reload();
        });

        // ---> NUEVO: Lógica del Buscador en Vivo <---
        const buscador = document.getElementById('buscador-medicamentos');
        
        if (buscador) {
            buscador.addEventListener('input', function() {
                const textoBusqueda = this.value.toLowerCase();
                // Seleccionamos todas las filas del cuerpo de la tabla
                const filas = document.querySelectorAll('tbody tr');

                filas.forEach(fila => {
                    // Buscamos el texto dentro de la celda que tiene la clase 'med-name'
                    const nombreMedicamento = fila.querySelector('.med-name').innerText.toLowerCase();
                    
                    // Si el nombre incluye lo que escribimos, la mostramos, sino la ocultamos
                    if (nombreMedicamento.includes(textoBusqueda)) {
                        fila.style.display = '';
                    } else {
                        fila.style.display = 'none';
                    }
                });
            });
        }
    </script>
</body>
</html>