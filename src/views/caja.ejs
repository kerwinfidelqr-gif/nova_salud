<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Punto de Venta - Nova Salud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_caja.css">
</head>
<body>
    <div id="alertas-sistema" class="contenedor-alertas"></div>
    <main class="container caja-master">
        <header class="header-top">
            <div class="titulos">
                <h1>Punto de Venta</h1>
                <p class="subtitle">Atención al cliente y despacho de medicamentos</p>
            </div>
            <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</a>
        </header>
        <hr class="divider">
        <div class="caja-layout-grid">
            <section class="panel-izquierdo">
                <h3 class="panel-titulo"><i class="fa-solid fa-pills"></i> Medicamentos Disponibles</h3>
                <div class="table-wrapper">
                    <% if (productos && productos.length> 0) { %>
                        <div class="scroll-area">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Medicamento</th>
                                        <th>Precio</th>
                                        <th class="text-center">Stock</th>
                                        <th class="text-center">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for(let i=0; i < productos.length; i++) { %>
                                        <tr>
                                            <td class="med-name">
                                                <%= productos[i].nombre %>
                                            </td>
                                            <td class="precio-col">S/ <%= parseFloat(productos[i].precio).toFixed(2) %>
                                            </td>
                                            <td class="text-center" id="stock-<%= productos[i]._id %>">
                                                <span
                                                    class="stock-badge <%= productos[i].stock <= productos[i].minimoStock ? 'alerta-stock-texto' : 'stock-normal' %>">
                                                    <%= productos[i].stock %>
                                                </span>
                                            </td>
                                            <td class="text-center acciones-td">
                                                <button id="btn-<%= productos[i]._id %>" class="btn-vender"
                                                    onclick="agregarAlCarrito('<%= productos[i]._id %>', '<%= productos[i].nombre %>', <%= productos[i].precio %>, <%= productos[i].stock %>)"
                                                    <%=productos[i].stock===0 ? 'disabled' : '' %>>
                                                    <i class="fa-solid fa-cart-plus"></i>
                                                    <%= productos[i].stock===0 ? 'Agotado' : 'Agregar' %>
                                                </button>
                                            </td>
                                        </tr>
                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fa-solid fa-box-open"></i>
                                <p>No hay medicamentos registrados en el inventario.</p>
                            </div>
                            <% } %>
                </div>
            </section>
            <aside class="sidebar-carrito">
                <div class="tarjeta-card seccion-datos">
                    <h3 class="panel-titulo"><i class="fa-solid fa-user-injured"></i> Datos del Paciente</h3>
                    <input type="text" id="cliente-nombre" class="input-caja" placeholder="Nombre Completo">
                    <input type="text" id="cliente-dni" class="input-caja input-mb" placeholder="DNI / Documento">
                </div>
                <div class="tarjeta-card seccion-lista-carrito">
                    <h3 class="panel-titulo"><i class="fa-solid fa-cart-shopping"></i> Carrito de Compras</h3>
                    <div id="lista-carrito" class="carrito-box">
                        <p class="carrito-vacio">El carrito está vacío</p>
                    </div>
                    <div class="total-resumen">
                        <span class="total-texto">Total a Pagar:</span>
                        <strong class="total-monto">S/ <span id="total-carrito">0.00</span></strong>
                    </div>
                    <button onclick="confirmarVentaCarrito()" class="btn-procesar">
                        <i class="fa-solid fa-check-double"></i> Procesar Venta
                    </button>
                </div>
            </aside>

        </div>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        socket.emit('identificar-rol', '<%= role %>');
        function mostrarNotificacion(mensaje, tipo = 'info') {
            const alertasDiv = document.getElementById('alertas-sistema');
            if (!alertasDiv) return;
            const alerta = document.createElement('div');
            alerta.className = 'alerta-chat';
            if (tipo === 'exito') {
                alerta.style.borderLeftColor = '#43A047';
                alerta.style.color = '#2E7D32';
                alerta.innerHTML = `<i class="fa-solid fa-circle-check"></i> <span>${mensaje}</span>`;
            } else if (tipo === 'error') {
                alerta.style.borderLeftColor = '#EF5350'; 
                alerta.style.color = '#C62828';
                alerta.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> <span>${mensaje}</span>`;
            } else {
                alerta.innerHTML = `<i class="fa-solid fa-bell"></i> <span>${mensaje}</span>`;
            }

            alertasDiv.appendChild(alerta);
            setTimeout(() => { alerta.remove(); }, 4000);
        }
        socket.on('sincronizar-stock', (data) => {
            const celdaStock = document.getElementById('stock-' + data.idProducto);
            const botonVender = document.getElementById('btn-' + data.idProducto);
            if (celdaStock) {
                const badge = celdaStock.querySelector('.stock-badge');
                if (badge) badge.innerText = data.nuevoStock;
            }
            if (botonVender && data.nuevoStock === 0) {
                botonVender.disabled = true;
                botonVender.innerHTML = '<i class="fa-solid fa-ban"></i> Agotado';
            }
        });
        socket.on('alerta-stock', (data) => {
            mostrarNotificacion(`Aviso de Stock: ${data.mensaje}`, 'error');
        });
        socket.on('catalogo-actualizado', () => {
            window.location.reload();
        });
        let carrito = [];
        function agregarAlCarrito(id, nombre, precio, stockActual) {
            if (stockActual <= 0) return mostrarNotificacion('Este producto está agotado', 'error');
            const productoEnCarrito = carrito.find(p => p.id === id);
            if (productoEnCarrito) {
                if (productoEnCarrito.cantidad >= stockActual) {
                    return mostrarNotificacion('Límite de stock alcanzado.', 'error');
                }
                productoEnCarrito.cantidad++;
            } else {
                carrito.push({ id, nombre, precio: parseFloat(precio), cantidad: 1 });
            }
            actualizarVistaCarrito();
        }

        function quitarDelCarrito(id) {
            carrito = carrito.filter(p => p.id !== id);
            actualizarVistaCarrito();
        }

        function actualizarVistaCarrito() {
            const lista = document.getElementById('lista-carrito');
            const totalSpan = document.getElementById('total-carrito');
            lista.innerHTML = '';

            if (carrito.length === 0) {
                lista.innerHTML = '<p class="carrito-vacio">El carrito está vacío</p>';
                totalSpan.innerText = '0.00';
                return;
            }
            let total = 0;
            carrito.forEach(p => {
                total += (p.precio * p.cantidad);
                lista.innerHTML += `
                    <div class="item-carrito">
                        <div class="item-info">
                            <strong class="item-nombre">${p.nombre}</strong>
                            <span class="item-detalle">Cant: ${p.cantidad} x S/ ${p.precio.toFixed(2)}</span>
                        </div>
                        <div class="item-acciones">
                            <strong class="item-subtotal">S/ ${(p.precio * p.cantidad).toFixed(2)}</strong>
                            <button onclick="quitarDelCarrito('${p.id}')" class="btn-quitar" title="Quitar">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                `;
            });
            totalSpan.innerText = total.toFixed(2);
        }
        async function confirmarVentaCarrito() {
            if (carrito.length === 0) return mostrarNotificacion('Agrega medicamentos al carrito.', 'error');
            const nombre = document.getElementById('cliente-nombre').value.trim();
            const dni = document.getElementById('cliente-dni').value.trim();
            if (!nombre || !dni) return mostrarNotificacion('Ingresa los datos del paciente.', 'error');
            try {
                const respuesta = await fetch('/vender-carrito', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        clienteNombre: nombre,
                        clienteDni: dni,
                        productos: carrito,
                        totalVenta: parseFloat(document.getElementById('total-carrito').innerText)
                    })
                });
                const data = await respuesta.json();
                if (data.success) {
                    carrito = [];
                    actualizarVistaCarrito();
                    document.getElementById('cliente-nombre').value = '';
                    document.getElementById('cliente-dni').value = '';
                    mostrarNotificacion('¡Venta registrada con éxito!', 'exito');
                } else {
                    mostrarNotificacion('Error: ' + data.mensaje, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                mostrarNotificacion('Error al conectar con el servidor.', 'error');
            }
        }
    </script>
</body>
</html>