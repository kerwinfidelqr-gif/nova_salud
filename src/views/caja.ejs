<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Punto de Venta - Nova Salud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles_caja.css">
</head>
<body>
    <main class="container caja-container">
        <div class="header-top">
            <div class="titulos">
                <h1>Punto de Venta</h1>
                <p class="subtitle">Atención al cliente y despacho de medicamentos</p>
            </div>
            <div class="botones-top">
                <a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</a>
            </div>
        </div>
        <hr class="divider">
        <h3><i class="fa-solid fa-pills"></i> Medicamentos Disponibles</h3>
        <div class="table-wrapper">
            <% if (productos && productos.length> 0) { %>
                <div class="scroll-area">
                    <table width="100%">
                        <thead>
                            <tr>
                                <th>Medicamento</th>
                                <th>Precio</th>
                                <th style="text-align: center;">Stock</th>
                                <th style="text-align: center;">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let i=0; i < productos.length; i++) { %>
                                <tr>
                                    <td class="nombre-producto"><strong>
                                            <%= productos[i].nombre %>
                                        </strong></td>
                                    <td class="precio-producto">S/ <%= productos[i].precio %>
                                    </td>
                                    <td id="stock-<%= productos[i]._id %>" style="text-align: center;">
                                        <span class="stock-badge">
                                            <%= productos[i].stock %>
                                        </span>
                                    </td>
                                    <td style="text-align: center;">
                                        <button type="button" id="btn-<%= productos[i]._id %>" class="btn-vender"
                                            onclick="realizarVenta('<%= productos[i]._id %>')" <%=productos[i].stock===0
                                            ? 'disabled' : '' %>>
                                            <i class="fa-solid fa-cart-plus"></i> Vender
                                        </button>
                                    </td>
                                </tr>
                                <% } %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa-solid fa-box-open"></i>
                        <p>No hay medicamentos registrados en el inventario actual.</p>
                    </div>
                    <% } %>
        </div>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        socket.emit('identificar-rol', '<%= role %>');
        socket.on('sincronizar-stock', (data) => {
            const celdaStock = document.getElementById('stock-' + data.idProducto);
            const botonVender = document.getElementById('btn-' + data.idProducto);
            if (celdaStock) {
                celdaStock.querySelector('.stock-badge').innerText = data.nuevoStock;
            }
            if (botonVender && data.nuevoStock === 0) {
                botonVender.disabled = true;
                botonVender.innerHTML = '<i class="fa-solid fa-ban"></i> Agotado';
            }
        });
        async function realizarVenta(idProducto) {
            try {
                await fetch('/vender/' + idProducto, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
            } catch (error) {
                console.error('Error al realizar la venta:', error);
            }
        }
    </script>
</body>
</html>